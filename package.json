{
  "name": "terminal-manage",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "author": "kuyep",
  "repository": {
    "type": "git",
    "url": "https://github.com/WEBNSNM/dev-manage.git"
  },
  "scripts": {
    "server": "cd server && node index.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\" --names \"SERVER,CLIENT\" -c \"bgBlue.bold,bgGreen.bold\"",
    "start": "electron .",
    "startmenu": "electron . -- --show-menu",
    "pack": "node scripts/build-electron.js --dir",
    "dist": "node scripts/build-electron.js"
  },
  "build": {
    "appId": "com.terminalManage.app",
    "productName": "terminalManage",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "client/dist/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "client/dist/mac.png",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "terminalManage Installer"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WEBNSNM",
        "repo": "dev-manage"
      }
    ],
    "files": [
      "main.js",
      "server/**/*",
      "client/dist/**/*",
      "package.json",
      "!server/node_modules"
    ],
    "asar": true
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "cpu-features",
      "ssh2"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "fix-path": "3.0.0",
    "pidtree": "^0.6.0",
    "pidusage": "^4.0.1",
    "semver": "^7.7.4",
    "socket.io": "^4.8.3"
  }
}
